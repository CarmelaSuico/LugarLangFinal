<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.LugarLangFinal" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/primaryAesthetic</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/primaryLightAesthetic</item>
        <item name="colorOnPrimaryContainer">@color/primaryDark</item>

        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/accentAesthetic</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/primaryDark</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>

        <!-- Background colors -->
        <item name="android:windowBackground">@color/backgroundAesthetic</item>

        <!-- Typography -->
        <item name="textAppearanceHeadlineLarge">@style/TextAppearance.Material3.HeadlineLarge</item>
        <item name="fontFamily">sans-serif</item>
    </style>

    <style name="Theme.LugarLangFinal" parent="Base.Theme.LugarLangFinal" />

    <style name="HeaderText">
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="BodyText">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="SearchTextBlack">
        <item name="android:editTextColor">@color/black</item>
        <item name="android:textColorHint">#757575</item>
    </style>
</resources>
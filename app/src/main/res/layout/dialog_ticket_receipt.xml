<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="30dp"
    app:cardBackgroundColor="#D9D9D9">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Origin -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:layout_marginBottom="12dp">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/trip_origin_24px" app:tint="#333333"/>
            <TextView android:id="@+id/resOrigin" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:text="ORIGIN" android:textAllCaps="true" android:textColor="#333333" android:textStyle="bold"/>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#999999" android:layout_marginBottom="12dp"/>

        <!-- Destination -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:layout_marginBottom="24dp">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/location_on_24px" app:tint="#333333"/>
            <TextView android:id="@+id/resDestination" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:text="DESTINATION" android:textAllCaps="true" android:textColor="#333333" android:textStyle="bold"/>
        </LinearLayout>

        <!-- Pricing Rows -->
        <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Passenger Type:" android:textStyle="bold" android:textColor="#333333"/>
            <TextView android:id="@+id/resType" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="Regular" android:textColor="#333333"/>
        </RelativeLayout>

        <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Regular Fare Price:" android:textStyle="bold" android:textColor="#333333"/>
            <TextView android:id="@+id/resRegPrice" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="Php 0.00" android:textColor="#333333"/>
        </RelativeLayout>

        <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Discount:" android:textStyle="bold" android:textColor="#333333"/>
            <TextView android:id="@+id/resDiscount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="Php -0.00" android:textColor="#333333"/>
        </RelativeLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#666666" android:layout_marginBottom="8dp"/>

        <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="24dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Total Fare Price:" android:textStyle="bold" android:textColor="#333333" android:textSize="16sp"/>
            <TextView android:id="@+id/resTotal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="Php 0.00" android:textColor="#333333" android:textStyle="bold" android:textSize="16sp"/>
        </RelativeLayout>

        <!-- Okay Button -->
        <Button
            android:id="@+id/btnConfirmTicket"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:minWidth="120dp"
            android:layout_gravity="end"
            android:text="Okay"
            android:textAllCaps="false"
            android:backgroundTint="#009929"
            android:textColor="@color/white"
            app:cornerRadius="15dp"
            android:drawablePadding="8dp"
            android:drawableTint="@color/white"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>
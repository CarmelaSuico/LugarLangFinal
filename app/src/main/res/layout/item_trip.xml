<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="10dp"
    android:gravity="center_vertical"
    android:background="#BAA4B1">


    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="#D9D9D9"
        app:cardCornerRadius="10dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="10dp">

                <TextView
                    android:id="@+id/txtcode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vehicle Code: "
                    android:layout_marginBottom="10dp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/txtterminal1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Terminal 1: "
                    android:layout_marginBottom="10dp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/txtterminal2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Terminal 2: "
                    android:layout_marginBottom="10dp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/txtassigneddriver"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Assigned Driver: "
                    android:layout_marginBottom="10dp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/txtassignedconductor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Assigned Conductor: "
                    android:layout_marginBottom="10dp"
                    android:textStyle="bold"/>

                <Button
                    android:id="@+id/btnmoredetails"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:backgroundTint="#999999"
                    android:textStyle="bold"
                    android:layout_gravity="end"
                    android:text="More Detail" />

            </LinearLayout>

        </RelativeLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>
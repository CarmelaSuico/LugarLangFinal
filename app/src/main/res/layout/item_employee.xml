<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    app:strokeColor="#1A000000"
    app:cardBackgroundColor="@color/white">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/employee_icon"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:padding="12dp"
            android:background="@color/primaryLightAesthetic"
            app:srcCompat="@drawable/person_24px"
            app:tint="@color/primaryAesthetic"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Medium" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toRightOf="@id/employee_icon"
            android:layout_toLeftOf="@+id/imgedit"
            android:layout_marginStart="16dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtname"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Employee Name"
                android:textColor="@color/textDark"
                android:textSize="18sp"
                android:fontFamily="sans-serif-black" />

            <TextView
                android:id="@+id/txtrole"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Role"
                android:textColor="@color/primaryAesthetic"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:textAllCaps="true"
                android:letterSpacing="0.05" />

            <View
                android:layout_width="40dp"
                android:layout_height="1dp"
                android:background="#1A000000"
                android:layout_marginVertical="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/txtid"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ID: 0000"
                    android:textColor="@color/textSecondary"
                    android:textSize="12sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" • "
                    android:textColor="@color/textSecondary"
                    android:textSize="12sp" />
                <TextView
                    android:id="@+id/txtfranchise"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Franchise Name"
                    android:textColor="@color/textSecondary"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/txtassignedunit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Assigned Unit: Bus"
                android:textColor="@color/textSecondary"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium" />

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/imgedit"
            style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            app:icon="@drawable/edit_24px"
            app:iconTint="@color/primaryAesthetic"
            android:backgroundTint="@color/primaryLightAesthetic"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Medium" />

    </RelativeLayout>

</com.google.android.material.card.MaterialCardView>
<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".AdminDashboard"
    android:background="@color/backgroundAesthetic">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <RelativeLayout
            android:id="@+id/top_header"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:background="@drawable/top_deisgn"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:layout_marginBottom="40dp"
                android:fontFamily="sans-serif-black"
                android:text="Admin\nDashboard"
                android:textColor="@color/white"
                android:textSize="32sp"
                android:lineSpacingExtra="4dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnadminsettings"
                style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentEnd="true"
                android:layout_alignParentTop="true"
                app:icon="@drawable/settings_24px"
                app:iconTint="@color/white"
                android:backgroundTint="#33FFFFFF" />

        </RelativeLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:clipToPadding="false"
        android:layout_marginTop="-30dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="40dp">

            <!-- Employee Management -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/white">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="24dp">

                    <ImageView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:src="@drawable/person_24px"
                        app:tint="@color/primaryLightAesthetic"
                        android:layout_alignParentEnd="true"
                        android:alpha="0.2"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Staff &amp; Workforce"
                        android:textColor="@color/textSecondary"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-bold"
                        android:textAllCaps="true"
                        android:letterSpacing="0.1"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Employee\nManagement"
                        android:textColor="@color/textDark"
                        android:textSize="20sp"
                        android:fontFamily="sans-serif-black" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnemployee"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentBottom="true"
                        android:text="Manage"
                        app:cornerRadius="12dp"
                        android:textColor="@color/primaryAesthetic"
                        app:backgroundTint="@color/primaryLightAesthetic"/>
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Route Management -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/white">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="24dp">

                    <ImageView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:src="@drawable/bus_railway_24px"
                        app:tint="@color/primaryLightAesthetic"
                        android:layout_alignParentEnd="true"
                        android:alpha="0.2"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Logistics &amp; Paths"
                        android:textColor="@color/textSecondary"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-bold"
                        android:textAllCaps="true"
                        android:letterSpacing="0.1"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Route\nManagement"
                        android:textColor="@color/textDark"
                        android:textSize="20sp"
                        android:fontFamily="sans-serif-black" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnroute"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentBottom="true"
                        android:text="Configure"
                        app:cornerRadius="12dp"
                        android:textColor="@color/primaryAesthetic"
                        app:backgroundTint="@color/primaryLightAesthetic"/>
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Transportation Management -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/white">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="24dp">

                    <ImageView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:src="@drawable/reorder_24px"
                        app:tint="@color/primaryLightAesthetic"
                        android:layout_alignParentEnd="true"
                        android:alpha="0.2"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fleet &amp; Units"
                        android:textColor="@color/textSecondary"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-bold"
                        android:textAllCaps="true"
                        android:letterSpacing="0.1"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Transportation\nManagement"
                        android:textColor="@color/textDark"
                        android:textSize="20sp"
                        android:fontFamily="sans-serif-black" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btntransportation"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentBottom="true"
                        android:text="Monitor"
                        app:cornerRadius="12dp"
                        android:textColor="@color/primaryAesthetic"
                        app:backgroundTint="@color/primaryLightAesthetic"/>
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Ticket Management -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/white">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="24dp">

                    <ImageView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:src="@drawable/transit_ticket_24px"
                        app:tint="@color/primaryLightAesthetic"
                        android:layout_alignParentEnd="true"
                        android:alpha="0.2"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Revenue &amp; Sales"
                        android:textColor="@color/textSecondary"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-bold"
                        android:textAllCaps="true"
                        android:letterSpacing="0.1"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Ticket\nManagement"
                        android:textColor="@color/textDark"
                        android:textSize="20sp"
                        android:fontFamily="sans-serif-black" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnticket"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentBottom="true"
                        android:text="Review"
                        app:cornerRadius="12dp"
                        android:textColor="@color/primaryAesthetic"
                        app:backgroundTint="@color/primaryLightAesthetic"/>
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".AdminDashboard"
    android:background="#BAA4B1">


    <LinearLayout
        android:id="@+id/top_header"
        android:layout_width="match_parent"
        android:layout_height="112dp"
        android:orientation="horizontal"
        android:background="@drawable/top_deisgn"
        android:padding="10dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="ADMIN DASHBOARD"
            android:textSize="35sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:textAlignment="center"
            android:gravity="center"/>

        <ImageButton
            android:id="@+id/btnadminsettings"
            android:layout_width="35dp"
            android:layout_height="35dp"
            app:srcCompat="@drawable/settings_24px"
            app:tint="@color/white"
            android:background="?attr/selectableItemBackground"
            android:scaleType="fitCenter"
            android:layout_gravity="center"
            android:layout_weight="0.5"/>

    </LinearLayout>


    <ScrollView
        android:layout_below="@id/top_header"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" >

<!--            Employee management-->
            <androidx.cardview.widget.CardView
                android:layout_width="366dp"
                android:layout_height="143dp"
                app:cardCornerRadius="20dp"
                android:layout_gravity="center"
                android:layout_marginTop="30dp"
                android:backgroundTint="#D9D9D9">

                <Button
                    android:id="@+id/btnemployee"
                    android:layout_width="317dp"
                    android:layout_height="67dp"
                    android:text="Employee Management"
                    android:textSize="20sp"
                    android:layout_gravity="center" />
            </androidx.cardview.widget.CardView>

            <!--            Route management-->
            <androidx.cardview.widget.CardView
                android:layout_width="366dp"
                android:layout_height="143dp"
                app:cardCornerRadius="20dp"
                android:layout_gravity="center"
                android:layout_marginTop="30dp"
                android:backgroundTint="#D9D9D9">

                <Button
                    android:id="@+id/btnroute"
                    android:layout_width="317dp"
                    android:layout_height="67dp"
                    android:text="Route Management"
                    android:textSize="20sp"
                    android:layout_gravity="center" />
            </androidx.cardview.widget.CardView>

            <!--            Transportation management-->
            <androidx.cardview.widget.CardView
                android:layout_width="366dp"
                android:layout_height="143dp"
                app:cardCornerRadius="20dp"
                android:layout_gravity="center"
                android:layout_marginTop="30dp"
                android:backgroundTint="#D9D9D9">

                <Button
                    android:id="@+id/btntransportation"
                    android:layout_width="317dp"
                    android:layout_height="67dp"
                    android:text="Transportation Management"
                    android:textSize="20sp"
                    android:layout_gravity="center" />
            </androidx.cardview.widget.CardView>

            <!--            Ticket management-->
            <androidx.cardview.widget.CardView
                android:layout_width="366dp"
                android:layout_height="143dp"
                app:cardCornerRadius="20dp"
                android:layout_gravity="center"
                android:layout_marginTop="30dp"
                android:backgroundTint="#D9D9D9">

                <Button
                    android:id="@+id/btnticket"
                    android:layout_width="317dp"
                    android:layout_height="67dp"
                    android:text="Ticket Management"
                    android:textSize="20sp"
                    android:layout_gravity="center" />
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>
</RelativeLayout>
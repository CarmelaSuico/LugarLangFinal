<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".driverconductor.StartEndTrip"
    android:background="@color/backgroundAesthetic">

    <org.osmdroid.views.MapView
        android:id="@+id/mapStartEnd"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/top_header_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp"
        app:strokeWidth="0dp"
        app:cardBackgroundColor="#CCFFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="20dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/txtterminal1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Terminal 1"
                android:textSize="18sp"
                android:fontFamily="sans-serif-black"
                android:textColor="@color/primaryAesthetic"
                android:gravity="center"/>

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginHorizontal="12dp"
                app:srcCompat="@drawable/arrow_forward_24px"
                app:tint="@color/textSecondary" />

            <TextView
                android:id="@+id/txtterminal2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Terminal 2"
                android:textSize="18sp"
                android:fontFamily="sans-serif-black"
                android:textColor="@color/primaryAesthetic"
                android:gravity="center"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnEndTrip"
        android:layout_width="wrap_content"
        android:layout_height="64dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="40dp"
        android:text="Finish Current Trip"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:backgroundTint="#EF4444"
        android:fontFamily="sans-serif-black"
        android:paddingHorizontal="32dp"
        app:cornerRadius="32dp"
        app:elevation="8dp"
        app:icon="@drawable/close_24px"
        app:iconGravity="textStart" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".commuter.SuggestedRoutes"
    android:background="#BAA4B1">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="10dp"
        android:paddingLeft="10dp"
        android:gravity="center_horizontal">

        <ImageButton
            android:id="@+id/btnback"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:scaleType="centerCrop"
            android:layout_alignParentTop="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:srcCompat="@drawable/arrow_back_24px"
            app:tint="@color/white"
            android:layout_gravity="left"
            android:layout_marginBottom="10dp"/>

        <!-- Origin Search Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_origin"
            android:layout_width="360dp"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/white">

            <androidx.appcompat.widget.SearchView
                android:id="@+id/searchorigin"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:defaultQueryHint="Origin place..."
                app:searchIcon="@drawable/trip_origin_24px"
                app:iconifiedByDefault="false"
                app:queryBackground="@android:color/transparent" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Destination Search Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_destination"
            android:layout_width="360dp"
            android:layout_height="56dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/white">

            <androidx.appcompat.widget.SearchView
                android:id="@+id/searchdestination"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:defaultQueryHint="Destination place..."
                app:iconifiedByDefault="false"
                app:searchIcon="@drawable/location_on_24px"
                app:queryBackground="@android:color/transparent" />
        </com.google.android.material.card.MaterialCardView>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/black"
            android:layout_marginVertical="16dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:id="@+id/recyclerView"
            android:layout_margin="16dp"/>

    </LinearLayout>




</androidx.coordinatorlayout.widget.CoordinatorLayout>
<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="70dp"
    android:background="#BA007C"
    android:forceDarkAllowed="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal">

        <!--        transportation Dashboard-->
        <LinearLayout
            android:id="@+id/btntransportdashboard"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageButton
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:src="@drawable/person_24px"
                android:background="@drawable/pill_background"
                app:tint="@color/nav_color"
                android:duplicateParentState="true"
                android:clickable="false" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Transportation Dashboard"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:textAlignment="center"/>
        </LinearLayout>

        <!--        Assigned a Driver/Conductor to a Route-->
        <LinearLayout
            android:id="@+id/btnassinedriver"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageButton
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:src="@drawable/bus_railway_24px"
                android:background="@drawable/pill_background"
                app:tint="@color/nav_color"
                android:duplicateParentState="true"
                android:clickable="false" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Assigned a Driver/Conductor"
                android:textAlignment="center"
                android:textStyle="bold"
                android:textColor="@color/white"/>
        </LinearLayout>

        <!--        Back-->
        <LinearLayout
            android:id="@+id/btnback"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageButton
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:src="@drawable/undo_24px"
                android:background="@drawable/pill_background"
                app:tint="@color/nav_color"
                android:duplicateParentState="true"
                android:clickable="false" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Back"
                android:textStyle="bold"
                android:textColor="@color/white"/>
        </LinearLayout>


    </LinearLayout>
</LinearLayout>
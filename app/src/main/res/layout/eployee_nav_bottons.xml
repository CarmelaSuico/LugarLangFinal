<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="80dp"
    android:background="#BA007C"
    android:forceDarkAllowed="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:baselineAligned="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Employee Dashboard Button -->
        <LinearLayout
            android:id="@+id/btnemployeedashboard"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:padding="4dp"
            android:background="?attr/selectableItemBackground">

            <ImageButton
                android:layout_width="48dp"
                android:layout_height="32dp"
                android:src="@drawable/person_24px"
                android:background="@drawable/pill_background"
                app:tint="@color/nav_color"
                android:duplicateParentState="true"
                android:clickable="false"
                android:scaleType="fitCenter"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Employee Dashboard"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:gravity="center"
                android:maxLines="1"
                app:autoSizeTextType="uniform"
                app:autoSizeMinTextSize="10sp"
                app:autoSizeMaxTextSize="12sp"/>
        </LinearLayout>

        <!-- Add New Employee Button -->
        <LinearLayout
            android:id="@+id/btnaddnewemployee"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:padding="4dp"
            android:background="?attr/selectableItemBackground">

            <ImageButton
                android:layout_width="48dp"
                android:layout_height="32dp"
                android:src="@drawable/add_circle_24px"
                android:background="@drawable/pill_background"
                app:tint="@color/nav_color"
                android:duplicateParentState="true"
                android:clickable="false"
                android:scaleType="fitCenter"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Add New Employee"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:gravity="center"
                android:maxLines="1"
                app:autoSizeTextType="uniform"
                app:autoSizeMinTextSize="10sp"
                app:autoSizeMaxTextSize="12sp"/>
        </LinearLayout>

        <!-- Back Button -->
        <LinearLayout
            android:id="@+id/btnback"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:padding="4dp"
            android:background="?attr/selectableItemBackground">

            <ImageButton
                android:layout_width="48dp"
                android:layout_height="32dp"
                android:src="@drawable/undo_24px"
                android:background="@drawable/pill_background"
                app:tint="@color/nav_color"
                android:duplicateParentState="true"
                android:clickable="false"
                android:scaleType="fitCenter"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Back to Dashboard"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:gravity="center"
                android:maxLines="1"
                app:autoSizeTextType="uniform"
                app:autoSizeMinTextSize="10sp"
                app:autoSizeMaxTextSize="12sp"/>
        </LinearLayout>

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
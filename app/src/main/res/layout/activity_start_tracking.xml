<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#BAA4B1"
    tools:context=".commuter.StartTracking">

    <!-- The Map View for Real-time Tracking -->
    <org.osmdroid.views.MapView
        android:id="@+id/mapTracking"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Back Button to return to Details -->
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_margin="16dp"
        android:src="@drawable/arrow_back_24px"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/black"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:scaleType="centerCrop"/>

    <!-- Top Status Overlay (e.g., "Waiting for the Jeepney") -->
    <TextView
        android:id="@+id/tvStatusHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Waiting for the Jeepney"
        android:textColor="@color/black"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Floating Tracking Info Card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Route Header: Origin > Destination -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginHorizontal="8dp"
                    android:src="@drawable/trip_origin_24px"
                    app:tint="#880E4F" />

                <TextView
                    android:id="@+id/tvTrackingOrigin"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Origin"
                    android:textColor="@color/black"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginHorizontal="8dp"
                    android:src="@drawable/location_on_24px"
                    app:tint="#880E4F" />

                <TextView
                    android:id="@+id/tvTrackingDest"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Destination"
                    android:textColor="@color/black"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="12dp"
                android:background="#DDDDDD" />

            <!-- Details Section -->
            <TextView
                android:id="@+id/tvLiveETA"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Estimated Time of Arrival: 10:00 AM"
                android:textColor="@color/black" />

            <TextView
                android:id="@+id/tvTrackingPlate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Plate Number: CEB-2010"
                android:textColor="@color/black" />

            <!-- Stop Button -->
            <TextView
                android:id="@+id/btnStopTracking"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="12dp"
                android:drawablePadding="4dp"
                android:text="Stop Tracking ▶"
                android:textColor="#880E4F"
                android:textStyle="bold"
                app:drawableTint="#880E4F" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    app:strokeColor="#1A000000"
    app:cardBackgroundColor="@color/white">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Icon Section -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/route_icon"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:padding="12dp"
            android:background="#F5F5F5"
            app:srcCompat="@drawable/bus_railway_24px"
            app:tint="@color/primaryAesthetic"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Medium"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true" />

        <!-- Action Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnmoredetails"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:text="Details"
            android:textSize="12sp"
            android:fontFamily="sans-serif-black" />

        <!-- Content Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/route_icon"
            android:layout_toStartOf="@id/btnmoredetails"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"
            android:orientation="vertical"
            android:layout_centerVertical="true">

            <TextView
                android:id="@+id/txtcode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ROUTE CODE"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:fontFamily="sans-serif-black" />

            <TextView
                android:id="@+id/txtstatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Active"
                android:textColor="@color/primaryAesthetic"
                android:textSize="11sp"
                android:fontFamily="sans-serif-bold"
                android:textAllCaps="true" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="vertical"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/txtterminal1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Start"
                    android:textColor="#444444"
                    android:textSize="13sp"
                    android:maxWidth="80dp"
                    android:ellipsize="end"
                    android:maxLines="1" />

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginHorizontal="6dp"
                    android:src="@drawable/arrow_forward_24px"
                    app:tint="#888888" />

                <TextView
                    android:id="@+id/txtterminal2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="End"
                    android:textColor="#444444"
                    android:textSize="13sp"
                    android:maxWidth="80dp"
                    android:ellipsize="end"
                    android:maxLines="1" />
            </LinearLayout>

            <TextView
                android:id="@+id/txtdistance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="0.0 KM"
                android:textColor="#888888"
                android:textSize="12sp" />

        </LinearLayout>
    </RelativeLayout>
</com.google.android.material.card.MaterialCardView>